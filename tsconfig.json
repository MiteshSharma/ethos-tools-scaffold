{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "declaration": false,
    "types": ["node"],
    "typeRoots": ["./typings", "./node_modules/@types"]
  },
  "include": ["src/**/*", "typings/**/*"],
  "exclude": ["node_modules", "dist"]
}
